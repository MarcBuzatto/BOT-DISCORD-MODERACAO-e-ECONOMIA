# ============================================================
# BOT DISCORD - MODERACAO + ECONOMIA
# Desenvolvido por: MARKIZIN
# ============================================================
#
# COMO CONFIGURAR:
# 1. Renomeie este arquivo de ".env.example" para ".env"
# 2. Substitua "SEU_TOKEN_AQUI" pelo token do seu bot
#
# COMO OBTER O TOKEN:
# 1. Acesse: https://discord.com/developers/applications
# 2. Clique no seu bot > Bot > Reset Token
# 3. Copie o token e cole abaixo
#
# IMPORTANTE: Nunca compartilhe seu token!
# ============================================================

DISCORD_TOKEN=SEU_TOKEN_AQUI
